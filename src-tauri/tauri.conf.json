{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CV Tailor",
  "version": "1.0.0",
  "identifier": "com.marcindeeec.cvtailor",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "CV Tailor",
        "width": 1100,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "shortDescription": "Local-first CV tailoring",
    "longDescription": "CV Tailor dopasowuje Twoje CV pod konkretną ofertę pracy. Działa lokalnie (local-first), a AI jest opcjonalne (BYOK / LocalAI / Ollama).",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
